@startuml QuanLyDanhMuc
+title Quản lý danh mục
+
+actor "Người dùng" as User
+participant CategoryController
+participant CategoryService
+participant SecurityUtils
+participant UserRepository
+participant CategoryRepository
+participant CategoryMapper
+
+== Danh sách danh mục ==
+User -> CategoryController: GET /categories?type
+CategoryController -> CategoryService: getCategoriesByUser(type)
+CategoryService -> SecurityUtils: getCurrentUserId()
+CategoryService -> CategoryRepository: findRootCategoriesByUser(userId, type)
+loop mỗi danh mục gốc
+    CategoryService -> CategoryRepository: findByParentIdOrderByNameAsc(rootId)
+    CategoryService -> CategoryMapper: toResponse(root)
+    CategoryService -> CategoryMapper: toResponse(child)
+end
+CategoryService --> CategoryController: List<CategoryResponse>
+CategoryController --> User: ApiResponse
+
+== Tạo danh mục ==
+User -> CategoryController: POST /categories (CategoryRequest)
+CategoryController -> CategoryService: createCategory(request)
+CategoryService -> SecurityUtils: getCurrentUserId()
+CategoryService -> UserRepository: findById(userId)
+CategoryService -> CategoryRepository: existsByUserIdAndTypeAndNameAndParentId(...)
+alt có parentId
+    CategoryService -> CategoryRepository: findByIdAndUserId(parentId, userId)
+end
+CategoryService -> CategoryMapper: toCategory(request)
+CategoryService -> CategoryRepository: save(category)
+CategoryService -> CategoryMapper: toResponse(category)
+CategoryService --> CategoryController: CategoryResponse
+CategoryController --> User: ApiResponse
+
+== Cập nhật danh mục ==
+User -> CategoryController: PUT /categories/{id}
+CategoryController -> CategoryService: updateCategory(id, request)
+CategoryService -> SecurityUtils: getCurrentUserId()
+CategoryService -> CategoryRepository: findByIdAccessibleToUser(id, userId)
+CategoryService -> CategoryRepository: existsByUserIdAndTypeAndNameAndParentId(...)
+alt có parentId
+    CategoryService -> CategoryRepository: findByParentIdOrderByNameAsc(id)
+    CategoryService -> CategoryRepository: findByIdAndUserId(parentId, userId)
+end
+CategoryService -> CategoryMapper: updateCategory(request, category)
+CategoryService -> CategoryRepository: save(category)
+CategoryService -> CategoryMapper: toResponse(category)
+CategoryService --> CategoryController: CategoryResponse
+CategoryController --> User: ApiResponse
+
+== Xóa danh mục ==
+User -> CategoryController: DELETE /categories/{id}
+CategoryController -> CategoryService: deleteCategory(id)
+CategoryService -> SecurityUtils: getCurrentUserId()
+CategoryService -> CategoryRepository: findByIdAccessibleToUser(id, userId)
+CategoryService -> CategoryRepository: hasTransactions(id)
+CategoryService -> CategoryRepository: delete(category)
+CategoryService --> CategoryController: void
+CategoryController --> User: ApiResponse
+
+@enduml
