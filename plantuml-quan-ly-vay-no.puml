@startuml QuanLyVayNo
+title Quản lý vay nợ (debts và payments)
+
+actor "Người dùng" as User
+participant DebtController
+participant DebtService
+participant DebtCommonService
+participant SecurityUtils
+participant UserRepository
+participant DebtRepository
+participant DebtPaymentRepository
+participant DebtMapper
+
+== Danh sách khoản vay nợ ==
+User -> DebtController: GET /debts?type
+DebtController -> SecurityUtils: getCurrentUserId()
+DebtController -> DebtService: getAllDebt(userId, type)
+alt có type
+    DebtService -> DebtRepository: findByUserIdAndTypeWithPayments(userId, type)
+else tất cả
+    DebtService -> DebtRepository: findAllByUserIdWithPayments(userId)
+end
+DebtService -> DebtMapper: toDebtSumaryResponse(debt)
+DebtService --> DebtController: List<DebtSumaryResponse>
+DebtController --> User: ApiResponse
+
+== Tạo khoản vay nợ ==
+User -> DebtController: POST /debts (DebtCreateRequest)
+DebtController -> SecurityUtils: getCurrentUserId()
+DebtController -> DebtService: createDebt(userId, request)
+DebtService -> UserRepository: findById(userId)
+DebtService -> DebtMapper: toDebt(request)
+DebtService -> DebtRepository: save(debt)
+DebtService -> DebtMapper: toDebtResponse(debt)
+DebtService --> DebtController: DebtResponse
+DebtController --> User: ApiResponse
+
+== Cập nhật khoản vay nợ ==
+User -> DebtController: PUT /debts/{id}
+DebtController -> SecurityUtils: getCurrentUserId()
+DebtController -> DebtService: updateDebt(userId, id, request)
+DebtService -> DebtCommonService: findDebtOfUser(id, userId)
+DebtService -> DebtPaymentRepository: sumPaidByDebtId(id)
+DebtService -> DebtMapper: updateDebt(debt, request)
+DebtService -> DebtRepository: save(debt)
+DebtService -> DebtMapper: toDebtResponse(debt)
+DebtService --> DebtController: DebtResponse
+DebtController --> User: ApiResponse
+
+== Xóa khoản vay nợ ==
+User -> DebtController: DELETE /debts/{id}
+DebtController -> SecurityUtils: getCurrentUserId()
+DebtController -> DebtService: deleteDebt(id, userId)
+DebtService -> DebtCommonService: findDebtOfUser(id, userId)
+DebtService -> DebtRepository: delete(debt)
+DebtService --> DebtController: void
+DebtController --> User: ApiResponse
+
+== Thanh toán khoản nợ ==
+participant DebtPaymentController
+participant DebtPaymentService
+participant DebtPaymentMapper
+
+User -> DebtPaymentController: POST /debts/{debtId}/payments
+DebtPaymentController -> SecurityUtils: getCurrentUserId()
+DebtPaymentController -> DebtPaymentService: createPayment(debtId, userId, request)
+DebtPaymentService -> DebtCommonService: findDebtOfUser(debtId, userId)
+DebtPaymentService -> DebtPaymentRepository: sumPaidByDebtId(debtId)
+DebtPaymentService -> DebtPaymentMapper: toDebtPayment(request)
+DebtPaymentService -> DebtPaymentRepository: save(payment)
+DebtPaymentService -> DebtPaymentMapper: toDebtPaymentResponse(payment)
+DebtPaymentService --> DebtPaymentController: DebtPaymentResponse
+DebtPaymentController --> User: ApiResponse
+
+User -> DebtPaymentController: PUT /debts/{debtId}/payments/{paymentId}
+DebtPaymentController -> SecurityUtils: getCurrentUserId()
+DebtPaymentController -> DebtPaymentService: updatePayment(debtId, paymentId, request, userId)
+DebtPaymentService -> DebtCommonService: findDebtOfUser(debtId, userId)
+DebtPaymentService -> DebtPaymentRepository: findByIdAndDebtId(paymentId, debtId)
+DebtPaymentService -> DebtPaymentRepository: sumPaidByDebtId(debtId)
+DebtPaymentService -> DebtPaymentMapper: updateDebtPayment(payment, request)
+DebtPaymentService -> DebtPaymentRepository: save(payment)
+DebtPaymentService --> DebtPaymentController: DebtPaymentResponse
+DebtPaymentController --> User: ApiResponse
+
+User -> DebtPaymentController: DELETE /debts/{debtId}/payments/{paymentId}
+DebtPaymentController -> SecurityUtils: getCurrentUserId()
+DebtPaymentController -> DebtPaymentService: deletePayment(debtId, paymentId, userId)
+DebtPaymentService -> DebtCommonService: findDebtOfUser(debtId, userId)
+DebtPaymentService -> DebtPaymentRepository: findByIdAndDebtId(paymentId, debtId)
+DebtPaymentService -> DebtPaymentRepository: delete(payment)
+DebtPaymentService --> DebtPaymentController: void
+DebtPaymentController --> User: ApiResponse
+
+@enduml
