@startuml QuanLyDinhKy
+title Quản lý giao dịch định kỳ
+
+actor "Người dùng" as User
+participant RecurringTransactionController
+participant RecurringTransactionService
+participant SecurityUtils
+participant UserRepository
+participant AccountRepository
+participant CategoryRepository
+participant RecurringTransactionRepository
+participant RecurringTransactionMapper
+
+== Danh sách giao dịch định kỳ ==
+User -> RecurringTransactionController: GET /recurring-transactions?status
+RecurringTransactionController -> SecurityUtils: getCurrentUserId()
+RecurringTransactionController -> RecurringTransactionService: getAll(userId, status)
+alt có trạng thái
+    RecurringTransactionService -> RecurringTransactionRepository: findByUserIdAndStatus(userId, status)
+else tất cả đang hoạt động
+    RecurringTransactionService -> RecurringTransactionRepository: findAllActiveByUserId(userId)
+end
+RecurringTransactionService -> RecurringTransactionMapper: toSummaryList(list)
+RecurringTransactionService --> RecurringTransactionController: List<RecurringTransactionSummaryResponse>
+RecurringTransactionController --> User: ApiResponse
+
+== Tạo giao dịch định kỳ ==
+User -> RecurringTransactionController: POST /recurring-transactions
+RecurringTransactionController -> SecurityUtils: getCurrentUserId()
+RecurringTransactionController -> RecurringTransactionService: create(userId, request)
+RecurringTransactionService -> UserRepository: findById(userId)
+RecurringTransactionService -> AccountRepository: findByIdAndUserId(accountId, userId)
+RecurringTransactionService -> CategoryRepository: findByIdAndUserId(categoryId, userId)
+RecurringTransactionService -> RecurringTransactionMapper: toRecurringTransaction(request)
+RecurringTransactionService -> RecurringTransactionRepository: save(recurring)
+RecurringTransactionService -> RecurringTransactionMapper: toResponse(recurring)
+RecurringTransactionService --> RecurringTransactionController: RecurringTransactionResponse
+RecurringTransactionController --> User: ApiResponse
+
+== Cập nhật giao dịch định kỳ ==
+User -> RecurringTransactionController: PUT /recurring-transactions/{id}
+RecurringTransactionController -> SecurityUtils: getCurrentUserId()
+RecurringTransactionController -> RecurringTransactionService: update(id, userId, request)
+RecurringTransactionService -> RecurringTransactionRepository: findByIdAndUserId(id, userId)
+RecurringTransactionService -> RecurringTransactionMapper: updateRecurringTransaction(recurring, request)
+opt đổi tài khoản/danh mục
+    RecurringTransactionService -> AccountRepository: findByIdAndUserId(accountId, userId)
+    RecurringTransactionService -> CategoryRepository: findByIdAndUserId(categoryId, userId)
+end
+RecurringTransactionService -> RecurringTransactionRepository: save(recurring)
+RecurringTransactionService -> RecurringTransactionMapper: toResponse(recurring)
+RecurringTransactionService --> RecurringTransactionController: RecurringTransactionResponse
+RecurringTransactionController --> User: ApiResponse
+
+== Bật/tắt và xóa ==
+User -> RecurringTransactionController: PATCH /recurring-transactions/{id}/toggle
+RecurringTransactionController -> SecurityUtils: getCurrentUserId()
+RecurringTransactionController -> RecurringTransactionService: toggle(id, userId, request)
+RecurringTransactionService -> RecurringTransactionRepository: findByIdAndUserId(id, userId)
+RecurringTransactionService -> RecurringTransactionRepository: save(recurring)
+RecurringTransactionService --> RecurringTransactionController: RecurringTransactionResponse
+RecurringTransactionController --> User: ApiResponse
+
+User -> RecurringTransactionController: DELETE /recurring-transactions/{id}
+RecurringTransactionController -> SecurityUtils: getCurrentUserId()
+RecurringTransactionController -> RecurringTransactionService: delete(id, userId)
+RecurringTransactionService -> RecurringTransactionRepository: findByIdAndUserId(id, userId)
+RecurringTransactionService -> RecurringTransactionRepository: save(recurring)
+RecurringTransactionService --> RecurringTransactionController: void
+RecurringTransactionController --> User: ApiResponse
+
+@enduml
